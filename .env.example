# Copy to `.env` or `.env.local` and adjust as needed.
# Vite exposes only variables prefixed with VITE_.

# API base path (no trailing slash). In dev, `/api` is proxied to Django at http://127.0.0.1:8000 (see vite.config.ts).
VITE_API_URL=/api

# If you run the frontend without the proxy (e.g. static build opened as file), use the full backend URL:
# VITE_API_URL=http://127.0.0.1:8000/api
